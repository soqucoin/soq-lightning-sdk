# soq-lightning-sdk — config for the stagenet 1b e2e runner (src/stagenet-e2e.ts).
#
# Copy to `.env` (which IS gitignored — verified) and fill REAL values.
# NEVER commit a populated .env. NEVER paste these values into chat/logs.
#
# NOTE: this runner reads SOQ_* vars. Buddy's C++ binary (soqucoin-stagenet-eltoo)
# reads its OWN ELTOO_* vars — two separate env sets, same underlying values.

# --- soqucoind JSON-RPC: sendrawtransaction + getrawtransaction (broadcast/confirm) ---
# Use the ROTATED hot RPC password (the pre-2026-06-15 value is burned).
SOQ_RPC_URL=http://HOST:38334
SOQ_RPC_USER=soqucoin_hot
SOQ_RPC_PASS=__ROTATED_RPC_PASSWORD__

# --- soq-signer: funds the v6 keyhash-2-of-2 output (/api/v1/send-to-witness-script) ---
# The bearer token is OPERATOR-ONLY — it never leaves your machine.
SOQ_SIGNER_URL=http://HOST:8550
SOQ_SIGNER_TOKEN=__SOQ_SIGNER_BEARER_TOKEN__

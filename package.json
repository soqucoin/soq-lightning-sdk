{
  "name": "soq-lightning-sdk",
  "version": "0.1.0-alpha.1",
  "description": "Soqucoin eLTOO Lightning SDK: quantum-safe (ML-DSA-44) instant payments on stagenet",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "soq-ln": "dist/cli.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "soqucoin",
    "lightning",
    "eltoo",
    "post-quantum",
    "ml-dsa",
    "dilithium",
    "quantum-safe",
    "payment-channels"
  ],
  "homepage": "https://github.com/soqucoin/soq-lightning-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soqucoin/soq-lightning-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/soqucoin/soq-lightning-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs",
    "canary": "npm run build && node dist/canary.js",
    "two-party-canary": "npm run build && node dist/two-party-canary.js",
    "self-custody-canary": "npm run build && node dist/self-custody-canary.js",
    "example:quickstart": "npm run build && node examples/quickstart.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@noble/hashes": "^1.4.0",
    "@noble/post-quantum": "^0.6.1",
    "bech32": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.4.0"
  }
}
